# העתק ל־.env.local והזן ערכים (הקובץ .env.local לא נכנס ל־git)

# Gemini — ל־Generate Workout (מקומי + Vercel). מספיק אחד מהשמות:
GEMINI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_AI_API_KEY=
# אופציונלי (ברירת מחדל בקוד: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# אנליטיקס — רק אם רוצה לבדוק את /api/event מקומית
# GITHUB_TOKEN=
# GITHUB_REPO=owner/repo
