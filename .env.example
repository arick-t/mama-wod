# העתק ל־.env.local והזן ערכים (הקובץ .env.local לא נכנס ל־git)

# Groq (Llama) — עדיפות על פני Gemini אם מוגדר. Vercel: Environment Variables + Redeploy.
GROQ_API_KEY=
# אופציונלי; ברירת מחדל: llama-3.3-70b-versatile
# GROQ_MODEL=

# Gemini — ל־Generate Workout (מקומי + Vercel). מספיק אחד מהשמות:
GEMINI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_AI_API_KEY=
# אופציונלי (ברירת מחדל בקוד: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# אנליטיקס — רק אם רוצה לבדוק את /api/event מקומית
# GITHUB_TOKEN=
# GITHUB_REPO=owner/repo
